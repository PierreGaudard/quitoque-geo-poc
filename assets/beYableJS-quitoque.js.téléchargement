var byPalHelper = (function () {
    var isInit = false;
    var isReset = false;
    var headerRoot;
    var headerOptions = {};
    var quitoqueHeader;

    var headerResize = function (el, options, pusher, root) {
        headerRoot = root;
        headerOptions = options;

        if (!isInit) {
            headerInit();
            isInit = true;
        }
        headerRefresh();
    };

    var headerInit = function () {     
        quitoqueHeader = document.querySelector(".checkout-header") || document.querySelector(".main-header");
        if (!quitoqueHeader) return;

        window.addEventListener("scroll", headerRefresh);

        var images = headerRoot.querySelectorAll("img");
        for (var i = 0; i < images.length; i++) {
            images[i].addEventListener("load", headerRefresh);
        }
    };

    var headerRefresh = function () {
        if (isReset) return;
        if (headerOptions.isFooter) return;
        if (!headerOptions.isSticky) return;
        if (!quitoqueHeader) return;

        const beyableCampaignHeight = headerRoot.offsetHeight;

        const quitoqueHeaderHeight = quitoqueHeader.offsetHeight;
        quitoqueHeader.style.width = "100%";
        document.body.style.paddingTop = quitoqueHeaderHeight + "px";

        if (window.innerWidth < 768) {
            quitoqueHeader.style.position = "fixed";
            quitoqueHeader.style.top = beyableCampaignHeight + "px";
        } else {
            quitoqueHeader.style.top = beyableCampaignHeight + "px";

            if (quitoqueHeader.classList.contains("sticky-top")) {
                quitoqueHeader.style.position = "fixed";
                headerRoot.style.position = "fixed";
            } else {
                quitoqueHeader.style.position = "absolute";
                headerRoot.style.position = "absolute";
            }
        }
    };

    var headerReset = function (el, options) {
        isReset = true;
        window.removeEventListener("scroll", headerRefresh);

        quitoqueHeader.style.position = "sticky";
        quitoqueHeader.style.top = "0px";

        document.body.style.paddingTop = "0px";
    };

    return {
        headerResize: headerResize,
        headerReset: headerReset,
    };
})();

var byPalHeaderResize = byPalHelper.headerResize;
